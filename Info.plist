<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist — IoMT CardioAI iOS App v1.1
  =========================================
  Non-sensitive configuration. Secrets live in iOS Keychain only.
  Backend URLs set via Xcode build scheme environment variables.
-->
<plist version="1.0">
<dict>
    <key>CFBundleName</key>             <string>CardioAI</string>
    <key>CFBundleDisplayName</key>      <string>CardioAI</string>
    <key>CFBundleIdentifier</key>       <string>com.cardioai.iomt</string>
    <key>CFBundleVersion</key>          <string>2</string>
    <key>CFBundleShortVersionString</key><string>1.1.0</string>
    <key>CFBundlePackageType</key>      <string>APPL</string>
    <key>CFBundleExecutable</key>       <string>$(EXECUTABLE_NAME)</string>

    <!-- Backend endpoints — set per Xcode scheme -->
    <key>CARDIOAI_WS_URL</key>          <string>$(CARDIOAI_WS_URL)</string>
    <key>CARDIOAI_API_URL</key>         <string>$(CARDIOAI_API_URL)</string>
    <key>CARDIOAI_CLIENT_ID</key>       <string>$(CARDIOAI_CLIENT_ID)</string>
    <key>CARDIOAI_ENVIRONMENT</key>     <string>$(CARDIOAI_ENVIRONMENT)</string>

    <!-- App Transport Security — TLS required -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- Bluetooth — required for device pairing -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>CardioAI uses Bluetooth to connect to your IoMT wearable device and stream real-time cardiac data.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>CardioAI uses Bluetooth to connect to your cardiac monitoring device.</string>

    <!-- HealthKit -->
    <key>NSHealthShareUsageDescription</key>
    <string>CardioAI reads your heart rate and blood pressure to monitor for cardiac events.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>CardioAI writes your IoMT device readings to Apple Health for your records.</string>

    <!-- Background modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-central</string>
        <string>processing</string>
        <string>fetch</string>
        <string>remote-notification</string>
    </array>

    <!-- Background task identifiers -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.cardioai.iomt.heartbeat</string>
    </array>

    <!-- Push notifications -->
    <key>UNUserNotificationUsageDescription</key>
    <string>CardioAI sends critical cardiac alerts that require immediate attention.</string>

    <!-- Sign in with Apple — add entitlement in Xcode Signing & Capabilities -->

    <!-- Supported devices — iPhone only -->
    <key>UIDeviceFamily</key>
    <array><integer>1</integer></array>

    <!-- iOS 17 minimum -->
    <key>MinimumOSVersion</key>
    <string>17.0</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UILaunchScreen</key>
    <dict/>

    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
</dict>
</plist>
